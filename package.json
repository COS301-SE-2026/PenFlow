{
  "name": "penflow",
  "version": "1.0.0",
  "private": true,
  "description": "PenFlow - Penetration Testing Pipeline Platform",
  "scripts": {
    "dev": "pnpm --parallel --filter ./frontend --filter ./backend dev",
    "build": "pnpm --recursive build",
    "test": "pnpm --recursive test",
    "test:coverage": "pnpm --recursive test:coverage",
    "lint": "pnpm --recursive lint",
    "lint:fix": "pnpm --recursive lint:fix",
    "type-check": "pnpm --recursive type-check",
    "clean": "pnpm --recursive exec rm -rf node_modules dist .next coverage"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch": "^9.0.5",
      "glob": "^10.3.10",
      "path-to-regexp": ">=8.4.0",
      "picomatch": ">=4.0.4",
      "express>path-to-regexp": "0.1.12"
    }
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "supabase": "^2.84.0"
  }
}
